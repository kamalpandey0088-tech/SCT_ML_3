# .env — Local development overrides
# Copy to .env and fill in your values. Never commit to version control.

# Path to trained model artefacts
MODELS_DIR=./models

# Allowed frontend origins (comma-separated list in production)
# ALLOWED_ORIGINS=["https://your-prod-domain.com"]

# PyTorch device: auto | cuda | mps | cpu
DEVICE=auto

# Rate limit (slowapi syntax: "N/period")
RATE_LIMIT=5/minute

# Max upload size in bytes (10 MB default)
MAX_UPLOAD_BYTES=10485760
